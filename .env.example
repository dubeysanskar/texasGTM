# TexasGTM — Environment Variables
# Copy this to .env and fill in your values

# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# JWT secret for auth tokens (generate a random 32+ char string)
JWT_SECRET=change-this-to-a-random-secret-string

# ═══ SMTP Account 1 (Primary) ═══
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@domain.com
SMTP_FROM_NAME=TexasGTM
SMTP_DAILY_LIMIT=30

# ═══ SMTP Account 2 (Rotation) ═══
# SMTP2_HOST=smtp.gmail.com
# SMTP2_PORT=465
# SMTP2_SECURE=true
# SMTP2_USER=your-second-email@domain.com
# SMTP2_PASSWORD=your-second-app-password
# SMTP2_FROM=your-second-email@domain.com
# SMTP2_FROM_NAME=TexasGTM
# SMTP2_DAILY_LIMIT=30

# ═══ SMTP Account 3 (Rotation) ═══
# SMTP3_HOST=smtp.gmail.com
# SMTP3_PORT=465
# SMTP3_SECURE=true
# SMTP3_USER=your-third-email@domain.com
# SMTP3_PASSWORD=your-third-app-password
# SMTP3_FROM=your-third-email@domain.com
# SMTP3_FROM_NAME=TexasGTM
# SMTP3_DAILY_LIMIT=30

# App
APP_URL=http://localhost:3000

# Auto Email — LLM Personalization (optional)
OPENAI_API_KEY=sk-your-openai-api-key-here
